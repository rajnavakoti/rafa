# Local or Docker setup
# IS_DOCKER = True

# Strorage options [in-memory, chromadb]
STORAGE_TYPE = "chromadb"

# Local environment variables
LOCAL_PERSIST_DB = "rafa/data/vector_db"
LOCAL_CHROMA_PERSIST_DB = "rafa/data/chroma_db"
LOCAL_CHUNK_SIZE = 256
LOCAL_CHUNK_OVERLAP = 5
LOCAL_EMBED_MODEL = "local:BAAI/bge-small-en-v1.5"
LOCAL_LLM_MODEL = "llama3:instruct"
LOCAL_DATA_DIR = "rafa/data/collections"
LOCAL_REQUIRED_EXTS = ".md"
LOCAL_FRIDAY_AVATAR = "rafa/assests/friday.png"
LOCAL_USER_AVATAR = "rafa/assests/user.png"
LOCAL_BANNER = "rafa/assests/tgif.png"
LOCAL_INTERMEDIATE_SERVER = "http://localhost:8000"
LOCAL_INTERMEDIATE_PORT = 8000
LOCAL_WEBSOCKET_SERVER = "http://localhost:8080"
LOCAL_CHAT_MEOMRY_TOKEN_LIMIT = 3900
LOCAL_OLLAMA_SERVER = "http://localhost:11434"
LOCAL_OLLAMA_SERVER_TIMEOUT = 90
LOCAL_CHAT_MODE = "condense_plus_context"


# Docker environment variables
DOCKER_PERSIST_DB = "/app/rafa/data/vector_db"
DOCKER_CHROMA_PERSIST_DB = "/app/rafa/data/chroma_db"
DOCKER_CHUNK_SIZE = 256
DOCKER_CHUNK_OVERLAP = 5
DOCKER_EMBED_MODEL = "local:BAAI/bge-small-en-v1.5"
DOCKER_LLM_MODEL = "llama3:instruct"
DOCKER_DATA_DIR = "/app/rafa/data/collections"
DOCKER_REQUIRED_EXTS = ".md"
DOCKER_FRIDAY_AVATAR = "/app/rafa/assests/friday.png"
DOCKER_USER_AVATAR = "/app/rafa/assests/user.png"
DOCKER_BANNER = "/app/rafa/assests/tgif.png"
DOCKER_INTERMEDIATE_SERVER = "http://intermediary_server:5001"
DOCKER_INTERMEDIATE_PORT = 5001
DOCKER_WEBSOCKET_SERVER = "http://websocket:5002"
DOCKER_CHAT_MEOMRY_TOKEN_LIMIT = 3900
DOCKER_OLLAMA_SERVER = "http://ollama-container:11434"
DOCKER_OLLAMA_SERVER_TIMEOUT = 90
DOCKER_CHAT_MODE = "condense_plus_context"

